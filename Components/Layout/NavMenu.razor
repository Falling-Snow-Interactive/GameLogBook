@implements IDisposable
@implements IAsyncDisposable
@using Microsoft.JSInterop
@inject UserProfileSession UserSession
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime

<nav class="nav-menu" aria-label="Main navigation">
    <input id="nav-menu-toggle"
           type="checkbox"
           title="Navigation menu"
           class="navbar-toggle-input"
           checked/>

    <div class="navbar-header">
        <NavLink class="navbar-logo-link" href="" Match="NavLinkMatch.All" aria-label="Home">
            <img class="navbar-logo" src="assets/logo_image.png" alt="Memory Card" />
        </NavLink>

        <label class="navbar-toggler"
               for="nav-menu-toggle"
               aria-label="Toggle navigation menu"
               title="Navigation menu">
            <span class="navbar-toggler-icon" aria-hidden="true"></span>
        </label>
    </div>

    <div class="navbar-body">
        <div class="nav-item">
            <NavLink class="nav-link" href="home">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span>
                <span>Home</span>
            </NavLink>
        </div>

        <div class="nav-spacer" aria-hidden="true"></div>

        <div class="nav-item">
            <NavLink class="nav-link" href="logs">
                <span class="bi bi-bookmark" aria-hidden="true"></span>
                <span>Logs</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="playthroughs">
                <span class="bi bi-journal-bookmark-fill" aria-hidden="true"></span>
                <span>Playthroughs</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="books">
                <span class="bi bi-book" aria-hidden="true"></span>
                <span>Books</span>
            </NavLink>
        </div>

        <div class="nav-spacer" aria-hidden="true"></div>

        <div class="navbar-section">
            <span class="bi bi-collection" aria-hidden="true"></span>
            <span>Libraries</span>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="games">
                <span class="bi bi-controller" aria-hidden="true"></span>
                <span>Games</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="platforms">
                <span class="bi bi-tv" aria-hidden="true"></span>
                <span>Platforms</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="companies">
                <span class="bi bi-building" aria-hidden="true"></span>
                <span>Companies</span>
            </NavLink>
        </div>
    </div>

    <div class="navbar-footer">
        <div class="navbar-profile-wrap" @ref="profileMenuElement">
            @if (isProfileMenuOpen)
            {
                <div class="navbar-profile-menu">
                    <button type="button" @onclick="GoToProfile">
                        <span class="bi bi-person" aria-hidden="true"></span>
                        <span>Profile</span>
                    </button>

                    <button type="button" @onclick="ChangeUser">
                        <span class="bi bi-arrow-left-right" aria-hidden="true"></span>
                        <span>Change User</span>
                    </button>

                    <button type="button" @onclick="GoToSettings">
                        <span class="bi bi-gear" aria-hidden="true"></span>
                        <span>Settings</span>
                    </button>

                    @if (UserSession.IsAdmin)
                    {
                        <button type="button" @onclick="GoToAdmin">
                            <span class="bi bi-shield-lock" aria-hidden="true"></span>
                            <span>Admin Users</span>
                        </button>

                        <button type="button" @onclick="GoToAdminSettings">
                            <span class="bi bi-sliders" aria-hidden="true"></span>
                            <span>Admin Settings</span>
                        </button>
                    }
                </div>
            }

            <button class="navbar-profile"
                    type="button"
                    aria-haspopup="menu"
                    aria-expanded="@isProfileMenuOpen"
                    @onclick="ToggleProfileMenu">
                <span class="bi bi-person" aria-hidden="true"></span>
                <span>@(UserSession.CurrentUser?.DisplayName ?? UserSession.CurrentUser?.Name ?? "Profile")</span>
                <span class="bi bi-chevron-up navbar-profile-caret" aria-hidden="true"></span>
            </button>
        </div>
    </div>
</nav>

@code {
    private bool isProfileMenuOpen;
    private ElementReference profileMenuElement;
    private DotNetObjectReference<NavMenu>? dotNetReference;
    private bool clickAwayConnected;

    protected override void OnInitialized()
    {
        UserSession.Changed += HandleUserSessionChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        dotNetReference = DotNetObjectReference.Create(this);
        await JsRuntime.InvokeVoidAsync("gameLogBookProfileMenu.observeClickAway", profileMenuElement, dotNetReference);
        clickAwayConnected = true;
    }

    private void ToggleProfileMenu()
    {
        isProfileMenuOpen = !isProfileMenuOpen;
    }

    [JSInvokable]
    public Task CloseProfileMenu()
    {
        if (!isProfileMenuOpen)
        {
            return Task.CompletedTask;
        }

        isProfileMenuOpen = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void GoToProfile()
    {
        NavigateAndClose("/profile");
    }

    private void ChangeUser()
    {
        UserSession.SignOut();
        NavigateAndClose("/profiles");
    }

    private void GoToSettings()
    {
        NavigateAndClose("/settings");
    }

    private void GoToAdmin()
    {
        NavigateAndClose("/admin/users");
    }

    private void GoToAdminSettings()
    {
        NavigateAndClose("/admin/settings");
    }

    private void NavigateAndClose(string uri)
    {
        isProfileMenuOpen = false;
        Navigation.NavigateTo(uri);
    }

    private void HandleUserSessionChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        UserSession.Changed -= HandleUserSessionChanged;
        dotNetReference?.Dispose();
    }

    public async ValueTask DisposeAsync()
    {
        if (clickAwayConnected)
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("gameLogBookProfileMenu.cleanup", profileMenuElement);
            }
            catch (JSDisconnectedException)
            {
            }
            catch (InvalidOperationException)
            {
            }
        }
    }
}
