<div class="@RootClass" @attributes="AttributesWithoutClass!">
    <span>@Label</span>

    <div class="@WidgetClass" style="@WidgetStyle" @ref="widgetElement">
        <div class="image-field-preview" aria-live="polite">
            @if (!string.IsNullOrWhiteSpace(previewSource))
            {
                <img src="@previewSource"
                     alt="@PreviewAltText" />
            }
            else
            {
                <span>No image set</span>
            }
        </div>

        <div class="image-field-controls" @ref="controlsElement">
            <div class="image-field-url-row">
                <input id="@UrlInputId"
                       class="@InputClass"
                       value="@urlInput"
                       @oninput="HandleUrlChanged"
                       placeholder="@UrlPlaceholder" />
                @* <button class="image-field-action-button" *@
                <button class="image-field-button image-field-action-button"
                        type="button"
                        disabled="@isBusy"
                        @onclick="DownloadUrlImage">
                    @* @(isBusy ? "Working..." : "Download") *@
                    <span class="bi bi-download"></span>
                </button>

                @if (SteamGridDbSearchEnabled && SteamGridDbImageType is not null)
                {
                    <button class="image-field-button button-colors-info image-field-steamgriddb-button"
                            type="button"
                            title="Search SteamGridDB"
                            aria-label="@($"Search SteamGridDB for {Label}")"
                            disabled="@isBusy"
                            @onclick="OpenSteamGridDbSearch">
                        <span class="bi bi-search" aria-hidden="true"></span>
                    </button>
                }
            </div>

            <label class="image-field-button-wide image-field-action-button image-field-upload-button">
                <InputFile class="image-field-upload-input"
                           OnChange="UploadImage"
                           accept="@Accept"></InputFile>
                <span>Upload</span>
            </label>

            <div class="image-field-action-row">
                <button class="image-field-reset-button"
                        type="button"
                        disabled="@isBusy"
                        @onclick="ResetImage">
                    Reset
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <p class="form-hint">@errorMessage</p>
    }
</div>
