@using GameLogBook.Components.Elements.GameEntry
@using GameLogBook.Models.Games
@using GameLogBook.Models.Companies

<div class="popup-backdrop">
    <div class="popup">
        <div class="popup-header">
            <h3>Add Game</h3>
            <button class="close-button"
                    type="button"
                    title="Close"
                    @onclick="HandleClose">
                X
            </button>
        </div>
        
        <div class="popup-content">
            <IGDBSearch Value="@searchInput"
                        Placeholder="Search for a game"
                        IsSearching="@isSearching"
                        OnInput="HandleSearchInput"
                        OnKeyDown="HandleKeyDown"
                        OnSearch="HandleSearch">
                @if (searchResults.Count > 0)
                {
                    <div class="search-results-dropdown">
                        @foreach (Game game in searchResults)
                        {
                            <GameEntry Game="game"
                                       ShowButtons="false"
                                       OnClick="@(() => HandleGameSelected(game))" />
                        }
                        @if (canLoadMore)
                        {
                            <div class="load-more-container">
                                <button class="load-more-button"
                                        type="button"
                                        @onclick="HandleLoadMore"
                                        disabled="@isLoadingMore">
                                    @(isLoadingMore ? "Loading..." : "Load more")
                                </button>
                            </div>
                        }
                    </div>
                }
            </IGDBSearch>

            <hr class="popup-divider"/>

            <div class="game-details-form">
                <label class="form-field form-field-full">
                    <span>Name</span>
                    <input class="game-detail-input"
                           @bind="gameName"
                           @bind:event="oninput"
                           placeholder="Game name"/>
                </label>

                <label class="form-field">
                    <span>Developer</span>
                    <select class="game-detail-input"
                            @bind="selectedDeveloperCompanyId">
                        <option value="">Select developer</option>
                        @foreach (Company company in companies)
                        {
                            <option value="@company.Id">@company.Name</option>
                        }
                    </select>
                </label>

                <label class="form-field">
                    <span>Publisher</span>
                    <select class="game-detail-input"
                            @bind="selectedPublisherCompanyId">
                        <option value="">Select publisher</option>
                        @foreach (Company company in companies)
                        {
                            <option value="@company.Id">@company.Name</option>
                        }
                    </select>
                </label>

                <label class="form-field">
                    <span>Release Date</span>
                    <input class="game-detail-input"
                           type="date"
                           @bind="releaseDate"
                           @bind:event="oninput"
                           placeholder="Release date"/>
                </label>

                <label class="form-field">
                    <span>IGDB ID</span>
                    <input class="game-detail-input"
                           type="number"
                           @bind="igdbId"
                           @bind:event="oninput"
                           placeholder="id"/>
                </label>

                <label class="form-field form-field-full">
                    <span>Cover URL</span>
                    <input class="game-detail-input"
                           @bind="coverUrl"
                           @bind:event="oninput"
                           placeholder="Cover image URL"/>
                </label>

                <label class="form-field form-field-full">
                    <span>Summary</span>
                    <textarea class="game-detail-textarea"
                          @bind="summary"
                          @bind:event="oninput"
                          placeholder="Summary"></textarea>
                </label>

                <div class="form-actions form-field-full">
                    <button class="save-button"
                            type="button"
                            @onclick="HandleSaveGame"
                            disabled="@string.IsNullOrWhiteSpace(gameName)">
                        Add to Library
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="error-message">@errorMessage</p>
        }
    </div>
</div>
