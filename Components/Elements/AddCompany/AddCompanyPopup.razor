@using GameLogBook.Components.Elements.AddPopup
@using GameLogBook.Models.Companies

<AddPopupShell Title="@PopupTitle"
               Description="Search the shared catalog, import from IGDB, or save a local fallback for offline use."
               SearchFor="@IgdbSearchFor.Companies"
               SearchPlaceholder="Search for a company"
               PopupClass="popup company-popup"
               FormClass="company-form"
               OnClose="HandleClose"
               OnCompanySelected="HandleCompanySelected">
    <label class="form-field form-field-full">
        <span>Name</span>
        <input class="company-input"
               @bind="companyName"
               @bind:event="oninput"
               placeholder="Company name" />
    </label>

    <label class="form-field form-field-full">
        <span>Logo image URL</span>
        <input class="company-input"
               value="@companyImageUrl"
               @oninput="HandleCompanyImageUrlChanged"
               placeholder="Download image from URL" />
    </label>

    <label class="form-field form-field-full">
        <span>Or upload logo image</span>
        <InputFile class="company-input"
                   OnChange="HandleCompanyImageFileSelected"
                   accept="image/png,image/jpeg,image/gif,image/webp" />
    </label>

    @if (!string.IsNullOrWhiteSpace(imageErrorMessage))
    {
        <p class="form-hint form-field-full">@imageErrorMessage</p>
    }

    @if (!string.IsNullOrWhiteSpace(companyPreviewSource))
    {
        <div class="form-field form-field-full image-preview-field">
            <span>Logo preview</span>
            <img class="image-preview"
                 src="@companyPreviewSource"
                 alt="@companyName logo preview" />
            <button class="collection-remove-button"
                    type="button"
                    @onclick="RemoveCompanyImage">
                Remove image
            </button>
        </div>
    }

    <div class="form-actions form-field-full">
        <button class="save-button"
                type="button"
                disabled="@(isSaving || string.IsNullOrWhiteSpace(companyName))"
                @onclick="HandleSaveCompany">
            @(isSaving ? "Saving image..." : SaveButtonText)
        </button>
    </div>
</AddPopupShell>
