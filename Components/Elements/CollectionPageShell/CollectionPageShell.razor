<div class="collection-page">
    <div class="collection-header">
        <div>
            <h3>@Title</h3>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p>@Description</p>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(AddButtonText))
        {
            <button class="collection-add-button"
                    type="button"
                    @onclick="OnAdd">
                @AddButtonText
            </button>
        }
    </div>

    @if (IsEmpty)
    {
        <div class="collection-empty-state">
            <h4>@EmptyTitle</h4>
            <p>@EmptyDescription</p>
        </div>
    }
    else
    {
        @ChildContent
    }
</div>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public string AddButtonText { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnAdd { get; set; }

    [Parameter]
    public bool IsEmpty { get; set; }

    [Parameter]
    public string EmptyTitle { get; set; } = string.Empty;

    [Parameter]
    public string EmptyDescription { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
