@using GameLogBook.Models.Games
@using GameLogBook.Components.Elements.AddPopup
@using GameLogBook.Components.Elements.CompanyElements

<AddPopupShell Title="@PopupTitle"
               SearchFor="@IgdbSearchFor.Games"
               SearchPlaceholder="Search for a game"
               OnClose="HandleClose"
               OnGameSelected="HandleGameSelected"
               LocalCompanies="@Companies">
    <div class="game-details-form">
        <label class="form-field form-field-full">
            <span>Name</span>
            <input class="game-detail-input"
                   @bind="name"
                   @bind:event="oninput"
                   placeholder="Game name"/>
        </label>

        <label class="form-field form-field">
            <span>Type</span>
            <EnumDropdown TEnum="GameType"
                          class="game-detail-input"
                          @bind-Value="type" />
        </label>

        <label class="form-field form-field">
            <span>Ownership</span>
            <OwnershipInputWidget/>
        </label>

        <div class="form-field form-field-full">
            @if (availableCompanies.Count == 0)
            {
                <p class="form-hint">No shared companies exist yet, so this game will save without developer or publisher links.</p>
            }
        </div>

        <div class="form-field">
            <span>Developer</span>
            <CompanySearch Companies="availableCompanies"
                           @bind-SelectedCompanyIds="selectedDeveloperIDs"
                           @bind-SearchText="developerSearchText"
                           OnCompanyAdded="HandleCompanyAdded"
                           Placeholder="Search companies..." />
        </div>

        <div class="form-field">
            <span>Publisher</span>
            <CompanySearch Companies="availableCompanies"
                           @bind-SelectedCompanyIds="selectedPublisherIDs"
                           @bind-SearchText="publisherSearchText"
                           OnCompanyAdded="HandleCompanyAdded"
                           Placeholder="Search companies..." />
        </div>

        <label class="form-field">
            <span>Release Date</span>
            <input class="game-detail-input"
                   type="date"
                   @bind="releaseDate"
                   @bind:event="oninput"
                   placeholder="Release date"/>
        </label>

        <label class="form-field">
            <span>IGDB ID</span>
            <input class="game-detail-input"
                   type="number"
                   @bind="igdb"
                   @bind:event="oninput"
                   placeholder="id"/>
        </label>

        <ImageFieldWidget @ref="coverImageField"
                          class="form-field-full"
                          Label="Cover"
                          FieldName="cover"
                          Category="games"
                          AspectRatioWidth="2"
                          AspectRatioHeight="3"
                          ImagePath="@coverImagePath"
                          PendingImageUrl="@coverImageUrl"
                          AltText="@($"{name} cover preview")" />

        <ImageFieldWidget @ref="heroImageField"
                          class="form-field-full"
                          Label="Hero"
                          FieldName="hero"
                          Category="games"
                          AspectRatioWidth="96"
                          AspectRatioHeight="31"
                          ImagePath="@heroImagePath"
                          PendingImageUrl="@heroImageUrl"
                          AltText="@($"{name} hero preview")" />

        <ImageFieldWidget @ref="logoImageField"
                          class="form-field-full"
                          Label="Logo"
                          FieldName="logo"
                          Category="games"
                          AspectRatioWidth="2"
                          AspectRatioHeight="1"
                          ImagePath="@logoImagePath"
                          PendingImageUrl="@logoImageUrl"
                          AltText="@($"{name} logo preview")" />
        
        <ImageFieldWidget @ref="iconImageField"
                          class="form-field-full"
                          Label="Icon"
                          FieldName="icon"
                          Category="games"
                          AspectRatioWidth="1"
                          AspectRatioHeight="1"
                          ImagePath="@iconImagePath"
                          PendingImageUrl="@iconImageUrl"
                          AltText="@($"{name} icon preview")" />

        @if (!string.IsNullOrWhiteSpace(imageErrorMessage))
        {
            <p class="form-hint form-field-full">@imageErrorMessage</p>
        }

        <label class="form-field form-field-full">
            <span>Summary</span>
            <textarea class="game-detail-textarea"
                  @bind="summary"
                  @bind:event="oninput"
                  placeholder="Summary"></textarea>
        </label>

        <div class="form-actions form-field-full">
            <button class="save-button"
                    type="button"
                    @onclick="HandleSaveGame"
                    disabled="@(isSaving || string.IsNullOrWhiteSpace(name))">
                @(isSaving ? "Saving image..." : SaveButtonText)
            </button>
        </div>
    </div>
</AddPopupShell>
