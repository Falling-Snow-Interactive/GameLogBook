@using VGL.Models.Games.Platforms

<div class="ownership-input-widget" @ref="ownershipGridElement">
    @if (Platforms.Count == 0)
    {
        <p class="form-hint">Add a platform before setting ownership.</p>
    }
    else
    {
        @foreach (var platform in OrderedPlatforms)
        {
            bool isSelected = IsSelected(platform.ID);
            bool hasLogo = !string.IsNullOrWhiteSpace(platform.Logo?.Path);

            <div class="ownership-row @(isSelected ? "ownership-row-selected" : null)"
                 data-ownership-platform-id="@platform.ID"
                 role="checkbox"
                 tabindex="0"
                 aria-checked="@isSelected"
                 aria-label="@platform.Name"
                 @key="platform.ID"
                 @onclick="() => TogglePlatform(platform.ID)"
                 @onkeydown="args => HandleRowKeyDown(platform.ID, args)">
                <div class="ownership-platform">
                    @if (hasLogo)
                    {
                        <span class="ownership-platform-logo-frame">
                            <LocalImage ImagePath="@platform.Logo?.Path"
                                        ImageClass="ownership-platform-logo"
                                        AltText="@($"{platform.Name} logo")"
                                        MissingText="@platform.Name"
                                        MaxWidth="220"
                                        MaxHeight="72">
                                <Placeholder>
                                    <span class="ownership-platform-name">@platform.Name</span>
                                </Placeholder>
                            </LocalImage>
                        </span>
                    }
                    else
                    {
                        <span class="ownership-platform-name">@platform.Name</span>
                    }
                </div>

                <div class="ownership-select-shell"
                     @onclick:stopPropagation="true"
                     @onpointerdown:stopPropagation="true"
                     @onkeydown:stopPropagation="true">
                    <div class="ownership-type-toggle" role="group" aria-label="@($"{platform.Name} ownership type")">
                        <button type="button"
                                class="@GetOwnershipOptionClass(platform.ID, OwnershipType.Physical)"
                                disabled="@(!isSelected)"
                                aria-pressed="@HasOwnershipType(platform.ID, OwnershipType.Physical)"
                                @onclick="() => ToggleOwnershipType(platform.ID, OwnershipType.Physical)">
                            Physical
                        </button>
                        <button type="button"
                                class="@GetOwnershipOptionClass(platform.ID, OwnershipType.Digital)"
                                disabled="@(!isSelected)"
                                aria-pressed="@HasOwnershipType(platform.ID, OwnershipType.Digital)"
                                @onclick="() => ToggleOwnershipType(platform.ID, OwnershipType.Digital)">
                            Digital
                        </button>
                        <button type="button"
                                class="@GetOwnershipOptionClass(platform.ID, OwnershipType.Subscription)"
                                disabled="@(!isSelected)"
                                aria-pressed="@HasOwnershipType(platform.ID, OwnershipType.Subscription)"
                                @onclick="() => ToggleOwnershipType(platform.ID, OwnershipType.Subscription)">
                            Subscription
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>
