@using VGL.Models.Games

<div class="entity-search"
     @onfocusin="HandleSearchFocusIn"
     @onfocusout="HandleSearchFocusOut">
    <div class="entity-search-anchor">
        <div class="search-input">
            <input class="detail-input"
                   value="@SearchText"
                   @oninput="OnSearchTextChanged"
                   placeholder="@Placeholder"
                   autocomplete="off"
                   aria-expanded="@ShouldShowDropdown" />
            <button class="plus-button"
                    type="button"
                    title="Add game"
                    aria-label="Add game"
                    @onclick="HandlePlusClicked">
                +
            </button>
        </div>

        @if (ShouldShowDropdown)
        {
            <div class="entity-search-results">
                @if (GameMatches.Count > 0)
                {
                    @foreach (Game game in GameMatches)
                    {
                        <button class="entity-search-result"
                                type="button"
                                @onclick="() => SelectGame(game)">
                            <span class="entity-search-result-icon bi bi-controller"
                                  aria-hidden="true"></span>

                            <span class="entity-search-result-copy">
                                <strong>@game.Name</strong>
                                <small>@GetGameBadge(game)</small>
                            </span>
                        </button>
                    }
                }
                else
                {
                    <p class="entity-search-empty">No games found.</p>
                }
            </div>
        }
    </div>

    @if (SelectedGame is not null)
    {
        <div class="manufacturer-chip-list">
            <span class="manufacturer-chip">
                @SelectedGame.Name
                <button type="button"
                        title="Remove @SelectedGame.Name"
                        aria-label="Remove @SelectedGame.Name"
                        @onclick="RemoveGame">
                    X
                </button>
            </span>
        </div>
    }
</div>
