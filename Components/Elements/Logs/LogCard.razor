<article class="log-card"
         role="button"
         tabindex="0"
         @onclick="OpenEditPopup">
    <div class="log-card-art">
        <LocalImage ImagePath="@(Log.Game.Hero?.Path ?? Log.Game.Cover?.Path)"
                    ImageClass="log-card-art-image"
                    AltText="@($"{Log.Game.Name} artwork")"
                    MaxWidth="640"
                    MaxHeight="300">
            <Placeholder>
                <div class="log-card-art-fallback">
                    <i class="bi bi-journal-text" aria-hidden="true"></i>
                </div>
            </Placeholder>
        </LocalImage>
    </div>

    <div class="log-card-content">
        <div class="log-card-header">
            <div class="log-card-cover">
                <LocalImage ImagePath="@Log.Game.Cover?.Path"
                            ImageClass="log-card-cover-image"
                            AltText="@($"{Log.Game.Name} cover")"
                            MaxWidth="180"
                            MaxHeight="270">
                    <Placeholder>
                        <div class="log-card-cover-fallback">
                            <i class="bi bi-controller" aria-hidden="true"></i>
                        </div>
                    </Placeholder>
                </LocalImage>
            </div>

            <div class="log-card-title-wrap">
                <div class="log-card-logo">
                    <LocalImage ImagePath="@Log.Game.Logo?.Path"
                                ImageClass="log-card-logo-image"
                                AltText="@($"{Log.Game.Name} logo")"
                                MaxWidth="320"
                                MaxHeight="100">
                        <Placeholder>
                            <span>@Log.Game.Name</span>
                        </Placeholder>
                    </LocalImage>
                </div>

                <div class="log-card-title">
                    <h4>@GetLogTitle(Log)</h4>
                    <p>
                        <span>@Log.Playthrough.Name</span>
                        <span aria-hidden="true">·</span>
                        <span>@Log.Platform.Name</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="log-card-meta">
            <span class="log-card-date">
                <i class="bi bi-calendar-event" aria-hidden="true"></i>
                @FormatShortDate(Log.StartedAt)
            </span>

            @if (Log.StatusChange is null)
            {
                <span class="log-status-pill log-status-none">No Status Change</span>
            }
            else
            {
                <span class="@($"status-badge status-badge-{Log.StatusChange.Value.ToString().ToLowerInvariant()}")">
                    @Log.StatusChange
                </span>
            }
        </div>

        <div class="log-card-stats" aria-label="@($"{GetLogTitle(Log)} stats")">
            <div>
                <strong>@FormatDuration(Log)</strong>
                <span>Duration</span>
            </div>
            <div>
                <strong>@FormatTimeRange(Log)</strong>
                <span>Time</span>
            </div>
            <div>
                <strong>@(Log.Location ?? "Not set")</strong>
                <span>Location</span>
            </div>
        </div>

        <div class="log-card-notes">
            <span>Notes</span>
            <p>@GetNotesPreview(Log)</p>
        </div>

        <div class="log-card-actions">
            <button class="log-card-time-action log-card-start-action"
                    type="button"
                    title="Set start time to now"
                    aria-label="Set start time to now for @GetLogTitle(Log)"
                    @onclick:stopPropagation="true"
                    @onclick="() => SetLogStartToNow(Log)">
                <i class="bi bi-play-fill" aria-hidden="true"></i>
                <span>Start</span>
            </button>
            <button class="log-card-time-action log-card-end-action"
                    type="button"
                    title="Set end time to now"
                    aria-label="Set end time to now for @GetLogTitle(Log)"
                    @onclick:stopPropagation="true"
                    @onclick="() => SetLogEndToNow(Log)">
                <i class="bi bi-stop-fill" aria-hidden="true"></i>
                <span>End</span>
            </button>
            <button class="button-dot button-colors-info log-card-action"
                    type="button"
                    title="Edit @GetLogTitle(Log)"
                    aria-label="Edit @GetLogTitle(Log)"
                    @onclick:stopPropagation="true"
                    @onclick="OpenEditPopup">
                <i class="bi bi-pencil-square" aria-hidden="true"></i>
            </button>
            <button class="button-dot button-colors-danger log-card-action"
                    type="button"
                    title="Remove @GetLogTitle(Log)"
                    aria-label="Remove @GetLogTitle(Log)"
                    @onclick:stopPropagation="true"
                    @onclick="() => RemoveLog(Log)">
                <i class="bi bi-trash" aria-hidden="true"></i>
            </button>
        </div>
    </div>
</article>