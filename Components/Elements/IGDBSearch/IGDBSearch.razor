<div class="igdb-search">
    <span class="igdb-search-label">@Label</span>

    <div class="igdb-search-anchor">
        <div class="igdb-search-row">
            <input class="igdb-search-input"
                   value="@searchInput"
                   placeholder="@Placeholder"
                   aria-label="@Label"
                   @oninput="HandleSearchInput"
                   @onkeydown="HandleSearchKeyDown" />

            <span class="igdb-search-status"
                  aria-hidden="true">
                @if (isSearching)
                {
                    <span class="igdb-search-spinner"></span>
                }
                else
                {
                    <span class="bi bi-search"></span>
                }
            </span>
        </div>

        @if (ShouldShowDropdown)
        {
            <div class="igdb-search-dropdown">
                @if (!string.IsNullOrWhiteSpace(searchErrorMessage))
                {
                    <p class="igdb-search-error">@searchErrorMessage</p>
                }
                else if (HasResults)
                {
                    <div class="igdb-search-results">
                        @switch (SearchFor)
                        {
                            case IgdbSearchFor.Games:
                                @foreach (GameLogBook.Models.Games.Game game in gameResults)
                                {
                                    <button class="igdb-search-result igdb-search-game-result"
                                            type="button"
                                            @onclick="() => SelectGame(game)">
                                        @if (!string.IsNullOrWhiteSpace(game.Cover?.PendingImageUrl))
                                        {
                                            <img class="igdb-search-result-cover"
                                                 src="@game.Cover.PendingImageUrl"
                                                 alt="@game.Name cover" />
                                        }
                                        else
                                        {
                                            <span class="igdb-search-result-cover-placeholder">
                                                No cover
                                            </span>
                                        }

                                        <span class="igdb-search-result-copy">
                                            <strong>@game.Name</strong>
                                            <small>@GetGameSummary(game)</small>

                                            @if (!string.IsNullOrWhiteSpace(game.Summary))
                                            {
                                                <span class="igdb-search-result-description">@game.Summary</span>
                                            }
                                        </span>
                                    </button>
                                }

                                break;
                            case IgdbSearchFor.Platforms:
                                @foreach (IgdbSearchPlatformResult result in platformResults)
                                {
                                    <button class="igdb-search-result"
                                            type="button"
                                            @onclick="() => SelectPlatform(result)">
                                        <span class="igdb-search-result-icon bi bi-tv"
                                              aria-hidden="true"></span>

                                        <span class="igdb-search-result-copy">
                                            <strong>@result.Platform.Name</strong>
                                            <small>@GetPlatformSummary(result)</small>
                                        </span>
                                    </button>
                                }

                                break;
                            case IgdbSearchFor.Companies:
                                @foreach (Models.Companies.Company company in companyResults)
                                {
                                    <button class="igdb-search-result"
                                            type="button"
                                            @onclick="() => SelectCompany(company)">
                                        @if (!string.IsNullOrWhiteSpace(company.PendingImageUrl))
                                        {
                                            <img class="igdb-search-result-logo"
                                                 src="@company.PendingImageUrl"
                                                 alt="@company.Name logo" />
                                        }
                                        else
                                        {
                                            <span class="igdb-search-result-icon bi bi-building"
                                                  aria-hidden="true"></span>
                                        }

                                        <span class="igdb-search-result-copy">
                                            <strong>@company.Name</strong>
                                            <small>@GetCompanyRoleSummary(company)</small>
                                        </span>
                                    </button>
                                }

                                break;
                        }

                        @if (canLoadMore)
                        {
                            <div class="igdb-search-load-more">
                                <button class="igdb-search-load-more-button"
                                        type="button"
                                        @onclick="HandleLoadMore"
                                        disabled="@isLoadingMore">
                                    @(isLoadingMore ? "Loading..." : "Load more")
                                </button>
                            </div>
                        }
                    </div>
                }
                else if (isSearching)
                {
                    <p class="igdb-search-empty">Searching IGDB...</p>
                }
                else if (hasSearched)
                {
                    <p class="igdb-search-empty">No results found.</p>
                }
            </div>
        }
    </div>
</div>
