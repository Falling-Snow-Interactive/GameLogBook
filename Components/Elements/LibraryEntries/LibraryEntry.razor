@using VGL.Models.Companies
@using VGL.Models.Games

<div class="library-entry-card"
     role="button"
     tabindex="0"
     @onclick="HandleClick">
    
    <div class="library-entry-hero">
        <LocalImage ImagePath="@Entry.Hero?.Path"
                    ImageClass="library-entry-hero-image"
                    AltText="@($"{Entry.Name} hero")"
                    MaxWidth="400"
                    MaxHeight="200"/>
    
    </div>

    <div class="library-entry-content">
        <div class="library-entry-header">
            <div class="library-entry-cover">
                <LocalImage ImagePath="@Entry.Cover?.Path"
                            ImageClass="library-entry-cover-image"
                            AltText="@($"{Entry.Name} cover")"
                            MaxWidth="200"
                            MaxHeight="300"/>
            </div>
            <div class="library-entry-logo">
                <LocalImage ImagePath="@Entry.Logo?.Path"
                            ImageClass="library-entry-logo-image"
                            AltText="@($"{Entry.Name} logo")"
                            MaxWidth="500"
                            MaxHeight="200"/>
            </div>
        </div>

        <div class="library-entry-body">
            <div class="library-entry-information">
                <label class="library-entry-title">@Entry.Name</label>
                <DateOnlyWidget Date="Entry.Date" 
                                Class="library-entry-release-date" />
                @if (Entry is Game game)
                {
                    <StarRating Value="game.Rating"
                                ReadOnly="true"
                                Class="library-entry-rating"
                                AriaLabel="@($"{game.Name} rating")" />
                }

                @if (HasCompanyIcons)
                {
                    <div class="library-entry-company-icons">
                        @if (DeveloperCompanies.Count > 0)
                        {
                            <div class="library-entry-company-group" aria-label="Developers">
                                @* <span class="library-entry-company-role">Dev</span> *@
                                <div class="library-entry-company-icon-row">
                                    @foreach (Company company in DeveloperCompanies)
                                    {
                                        <div class="library-entry-company-icon"
                                             title="@company.Name"
                                             aria-label="@company.Name">
                                            @if (!string.IsNullOrWhiteSpace(GetCompanyImagePath(company)))
                                            {
                                                <LocalImage ImagePath="@GetCompanyImagePath(company)"
                                                            ImageClass="library-entry-company-icon-image"
                                                            AltText="@($"{company.Name} icon")"
                                                            MissingText="@company.Name"
                                                            MaxWidth="40"
                                                            MaxHeight="40"/>
                                            }
                                            else
                                            {
                                                <span class="library-entry-company-icon-fallback">@GetCompanyInitials(company)</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        
                        @if (DeveloperCompanies.Count > 0
                             && PublisherCompanies.Count > 0)
                        {
                            <label> | </label>
                        }

                        @if (PublisherCompanies.Count > 0)
                        {
                            <div class="library-entry-company-group" aria-label="Publishers">
                                @* <span class="library-entry-company-role">Pub</span> *@
                                <div class="library-entry-company-icon-row">
                                    @foreach (Company company in PublisherCompanies)
                                    {
                                        <div class="library-entry-company-icon"
                                             title="@company.Name"
                                             aria-label="@company.Name">
                                            @if (!string.IsNullOrWhiteSpace(GetCompanyImagePath(company)))
                                            {
                                                <LocalImage ImagePath="@GetCompanyImagePath(company)"
                                                            ImageClass="library-entry-company-icon-image"
                                                            AltText="@($"{company.Name} icon")"
                                                            MaxWidth="40"
                                                            MaxHeight="40"/>
                                            }
                                            else
                                            {
                                                <span class="library-entry-company-icon-fallback">@GetCompanyInitials(company)</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        
            @if (!string.IsNullOrWhiteSpace(Entry.Summary))
            {
                <p class="library-entry-summary">@Entry.Summary</p>
            }
        </div>

        <div class="library-entry-footer">
            <div class="library-entry-buttons">
                @if (OnStart.HasDelegate)
                {
                    <button class="button-dot button-colors-success library-entry-button"
                            type="button"
                            title="Start session for @Entry.Name"
                            aria-label="Start session for @Entry.Name"
                            @onclick="HandleStart"
                            @onclick:stopPropagation="true">
                        <i class="bi bi-play-fill" aria-hidden="true"></i>
                    </button>
                }

                <button class="button-dot button-colors-info library-entry-button"
                        type="button" >
                    <i class="bi bi-pencil-square"></i>
                </button>
                
                <button class="button-dot button-colors-danger library-entry-button"
                        type="button"
                        @onclick="HandleRemove"
                        @onclick:stopPropagation="true">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
            
            <div class="library-entry-icon">
                <LocalImage ImagePath="@Entry.Icon?.Path"
                            ImageClass="library-entry-icon-image"
                            AltText="@($"{Entry.Name} icon")"
                            MaxWidth="50"
                            MaxHeight="50"/>
            </div>
        </div>
    </div>
</div>
