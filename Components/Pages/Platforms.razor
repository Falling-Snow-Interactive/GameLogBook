@page "/platforms"
@using GameLogBook.Components.Elements.AddPlatform
@using GameLogBook.Models.Platforms
@inherits CollectionPageBase<Platform>

<PageTitle>Platforms</PageTitle>

<CollectionPageShell Title="Platforms"
                     Description="The hardware and storefronts in your library."
                     AddButtonText="Add Platform"
                     OnAdd="OpenAddPopup"
                     IsEmpty="@(Items.Count == 0)"
                     EmptyTitle="No platforms added yet"
                     EmptyDescription="Add a platform to start organizing where you play.">
    <div class="collection-grid">
        @foreach (Platform platform in Items)
        {
            <article class="collection-card platform-card"
                     role="button"
                     tabindex="0"
                     @onclick="() => OpenEditPopup(platform)">
                @if (!string.IsNullOrWhiteSpace(platform.ImagePath))
                {
                    <LocalImage ImagePath="@platform.ImagePath"
                                ImageClass="platform-cover"
                                AltText="@($"{platform.Name} cover")">
                        <Placeholder>
                            <div class="platform-cover platform-cover-placeholder">
                                <span class="bi bi-controller" aria-hidden="true"></span>
                            </div>
                        </Placeholder>
                    </LocalImage>
                }
                else
                {
                    <div class="platform-cover platform-cover-placeholder">
                        <span class="bi bi-controller" aria-hidden="true"></span>
                    </div>
                }

                <div class="platform-content">
                    <div class="platform-title-row">
                        <h4>@platform.Name</h4>
                        <button class="collection-remove-button"
                                type="button"
                                title="Remove @platform.Name"
                                @onclick:stopPropagation="true"
                                @onclick="() => RemovePlatform(platform)">
                            Remove
                        </button>
                    </div>

                    <div class="platform-games">
                        <span class="platform-games-label">Games worked on</span>

                        @if (GetGameNames(platform).Count == 0)
                        {
                            <span class="platform-games-empty">No linked games yet</span>
                        }
                        else
                        {
                            <div class="game-chip-list">
                                @foreach (string gameName in GetGameNames(platform))
                                {
                                    <span class="game-chip">@gameName</span>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="platform-meta">
                    <span class="platform-badge neutral-badge">
                        @(platform.ReleaseDate?.ToString("yyyy-MM-dd") ?? "Unknown release date")
                    </span>
                </div>
            </article>
        }
    </div>
</CollectionPageShell>

@if (IsAddPopupOpen)
{
    <AddPlatformPopup OnClose="CloseAddPopup"
                      OnPlatformSelected="AddPlatform"
                      Games="games"
                      Companies="companies" />
}

@if (selectedPlatform is not null)
{
    <AddPlatformPopup OnClose="CloseEditPopup"
                      OnPlatformSelected="UpdatePlatform"
                      Games="games"
                      Companies="companies"
                      InitialPlatform="@selectedPlatform" />
}
