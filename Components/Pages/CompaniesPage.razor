@page "/companies"
@using VGL.Components.Elements.CollectionPageShell
@using VGL.Models.Companies
@using VGL.Components.Elements.LibraryEntries

@inherits CollectionPageBase<VGL.Models.Companies.Company>

<PageTitle>Companies</PageTitle>

<CollectionPageShell Title="Companies"
                     Description="Shared studios and publishers connected to your library."
                     AddButtonText="Add Company"
                     OnAdd="OpenAddPopup"
                     IsEmpty="@(Items.Count == 0)"
                     ViewMode="ViewMode"
                     ViewModeChanged="SetViewMode"
                     EmptyTitle="No companies added yet"
                     EmptyDescription="Add a company to start building the shared catalog.">
    @if (ViewMode == CollectionViewMode.Card)
    {
        <div class="collection-grid">
            @foreach (Company company in Items)
            {
                <LibraryEntry Entry="company"
                              OnClick="() => OpenEditPopup(company)"
                              OnRemove="() => HandleRemove(company)"/>
            }
        </div>
    }
    else
    {
        <div class="collection-table-scroll">
            <table class="collection-table">
                <thead>
                <tr>
                    <th scope="col">Company</th>
                    <th scope="col">Founded</th>
                    <th scope="col">Source</th>
                    <th scope="col">Roles</th>
                    <th scope="col">Linked Games</th>
                    <th scope="col">Linked Platforms</th>
                    <th scope="col" class="collection-table-actions-heading">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (Company company in Items)
                {
                    <tr role="button"
                        tabindex="0"
                        @onclick="() => OpenEditPopup(company)">
                        <td>
                            <div class="collection-table-primary-cell">
                                <span>@company.Name</span>
                                @if (!string.IsNullOrWhiteSpace(company.Summary))
                                {
                                    <small>@company.Summary</small>
                                }
                            </div>
                        </td>
                        <td>@FormatDate(company.FoundedDate)</td>
                        <td>@GetCompanySourceSummary(company)</td>
                        <td>@GetCompanyRoleSummary(company)</td>
                        <td>@FormatNames(GetGameNames(company))</td>
                        <td>@FormatNames(GetPlatformNames(company))</td>
                        <td>
                            <div class="collection-table-actions">
                                <button class="collection-table-action collection-table-action-edit"
                                        type="button"
                                        title="Edit @company.Name"
                                        aria-label="Edit @company.Name"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => OpenEditPopup(company)">
                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                </button>
                                <button class="collection-table-action collection-table-action-remove"
                                        type="button"
                                        title="Remove @company.Name"
                                        aria-label="Remove @company.Name"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => HandleRemove(company)">
                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</CollectionPageShell>
