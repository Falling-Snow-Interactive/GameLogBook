@page "/Playthroughs"
@using GameLogBook.Components.Elements.AddPlaythrough
@using GameLogBook.Models
@inherits CollectionPageBase<Playthrough>

<PageTitle>Playthroughs</PageTitle>

<CollectionPageShell Title="Playthroughs"
                     Description="Your saved playthroughs."
                     AddButtonText="Add Playthrough"
                     OnAdd="OpenAddPopup"
                     IsEmpty="@(Items.Count == 0)"
                     EmptyTitle="No playthroughs added yet"
                     EmptyDescription="Add a playthrough to start grouping your game sessions.">
    <ul class="collection-list">
        @foreach (Playthrough playthrough in Items)
        {
            <NamedCollectionEntry TItem="Playthrough"
                                  Item="playthrough"
                                  Title="@playthrough.Name"
                                  Description="@GetPlaythroughSummary(playthrough)"
                                  OnRemove="RemovePlaythrough" />
        }
    </ul>
</CollectionPageShell>

@if (IsAddPopupOpen)
{
    <AddPlaythroughPopup OnClose="CloseAddPopup"
                         OnPlaythroughSelected="AddPlaythrough"
                         LibraryGames="Games"/>
}
