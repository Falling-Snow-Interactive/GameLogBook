@page "/logs"

@using VGL.Models
@using VGL.Components.Elements.CollectionPageShell

@inherits LogbookPageBase<VGL.Models.GameLog>

<PageTitle>Logs</PageTitle>

<CollectionPageShell Title="Logs"
                     Description="Individual sessions across your playthroughs."
                     AddButtonText="Add Log"
                     OnAdd="OpenAddPopup"
                     IsEmpty="@(Items.Count == 0)"
                     ViewMode="ViewMode"
                     ViewModeChanged="SetViewMode"
                     EmptyTitle="No logs added yet"
                     EmptyDescription="Add a log after a play session to build your history.">
    @if (ViewMode == CollectionViewMode.Card)
    {
        <ul class="log-card-grid">
            @foreach (GameLog log in Items)
            {
                <li>
                    <article class="log-card"
                             role="button"
                             tabindex="0"
                             @onclick="() => OpenEditPopup(log)">
                        <div class="log-card-art">
                            <LocalImage ImagePath="@(log.Game.Hero?.Path ?? log.Game.Cover?.Path)"
                                        ImageClass="log-card-art-image"
                                        AltText="@($"{log.Game.Name} artwork")"
                                        MaxWidth="640"
                                        MaxHeight="300">
                                <Placeholder>
                                    <div class="log-card-art-fallback">
                                        <i class="bi bi-journal-text" aria-hidden="true"></i>
                                    </div>
                                </Placeholder>
                            </LocalImage>
                        </div>

                        <div class="log-card-content">
                            <div class="log-card-header">
                                <div class="log-card-cover">
                                    <LocalImage ImagePath="@log.Game.Cover?.Path"
                                                ImageClass="log-card-cover-image"
                                                AltText="@($"{log.Game.Name} cover")"
                                                MaxWidth="180"
                                                MaxHeight="270">
                                        <Placeholder>
                                            <div class="log-card-cover-fallback">
                                                <i class="bi bi-controller" aria-hidden="true"></i>
                                            </div>
                                        </Placeholder>
                                    </LocalImage>
                                </div>

                                <div class="log-card-title-wrap">
                                    <div class="log-card-logo">
                                        <LocalImage ImagePath="@log.Game.Logo?.Path"
                                                    ImageClass="log-card-logo-image"
                                                    AltText="@($"{log.Game.Name} logo")"
                                                    MaxWidth="320"
                                                    MaxHeight="100">
                                            <Placeholder>
                                                <span>@log.Game.Name</span>
                                            </Placeholder>
                                        </LocalImage>
                                    </div>

                                    <div class="log-card-title">
                                        <h4>@GetLogTitle(log)</h4>
                                        <p>
                                            <span>@log.Playthrough.Name</span>
                                            <span aria-hidden="true">·</span>
                                            <span>@log.Platform.Name</span>
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="log-card-meta">
                                <span class="log-card-date">
                                    <i class="bi bi-calendar-event" aria-hidden="true"></i>
                                    @FormatShortDate(log.StartedAt)
                                </span>

                                @if (log.StatusChange is null)
                                {
                                    <span class="log-status-pill log-status-none">No Status Change</span>
                                }
                                else
                                {
                                    <span class="@($"status-badge status-badge-{log.StatusChange.Value.ToString().ToLowerInvariant()}")">
                                        @log.StatusChange
                                    </span>
                                }
                            </div>

                            <div class="log-card-stats" aria-label="@($"{GetLogTitle(log)} stats")">
                                <div>
                                    <strong>@FormatDuration(log)</strong>
                                    <span>Duration</span>
                                </div>
                                <div>
                                    <strong>@FormatTimeRange(log)</strong>
                                    <span>Time</span>
                                </div>
                                <div>
                                    <strong>@(log.Location ?? "Not set")</strong>
                                    <span>Location</span>
                                </div>
                            </div>

                            <div class="log-card-notes">
                                <span>Notes</span>
                                <p>@GetNotesPreview(log)</p>
                            </div>

                            <div class="log-card-actions">
                                <button class="log-card-time-action log-card-start-action"
                                        type="button"
                                        title="Set start time to now"
                                        aria-label="Set start time to now for @GetLogTitle(log)"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => SetLogStartToNow(log)">
                                    <i class="bi bi-play-fill" aria-hidden="true"></i>
                                    <span>Start</span>
                                </button>
                                <button class="log-card-time-action log-card-end-action"
                                        type="button"
                                        title="Set end time to now"
                                        aria-label="Set end time to now for @GetLogTitle(log)"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => SetLogEndToNow(log)">
                                    <i class="bi bi-stop-fill" aria-hidden="true"></i>
                                    <span>End</span>
                                </button>
                                <button class="button-dot button-colors-info log-card-action"
                                        type="button"
                                        title="Edit @GetLogTitle(log)"
                                        aria-label="Edit @GetLogTitle(log)"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => OpenEditPopup(log)">
                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                </button>
                                <button class="button-dot button-colors-danger log-card-action"
                                        type="button"
                                        title="Remove @GetLogTitle(log)"
                                        aria-label="Remove @GetLogTitle(log)"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => RemoveLog(log)">
                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                    </article>
                </li>
            }
        </ul>
    }
    else
    {
        <div class="collection-table-scroll">
            <table class="collection-table logbook-table">
                <thead>
                <tr>
                    <th scope="col">Log</th>
                    <th scope="col">Game</th>
                    <th scope="col">Playthrough</th>
                    <th scope="col">Platform</th>
                    <th scope="col">Status Change</th>
                    <th scope="col">Started</th>
                    <th scope="col">Ended</th>
                    <th scope="col">Duration</th>
                    <th scope="col">Location</th>
                    <th scope="col">Notes</th>
                    <th scope="col" class="collection-table-actions-heading">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (GameLog log in Items)
                {
                    <tr role="button"
                        tabindex="0"
                        @onclick="() => OpenEditPopup(log)">
                        <td>
                            <div class="collection-table-primary-cell">
                                <span>@GetLogTitle(log)</span>
                                <small>@FormatDateTime(log.StartedAt)</small>
                            </div>
                        </td>
                        <td>@log.Game.Name</td>
                        <td>@log.Playthrough.Name</td>
                        <td>@log.Platform.Name</td>
                        <td>@(log.StatusChange?.ToString() ?? "None")</td>
                        <td>@FormatDateTime(log.StartedAt)</td>
                        <td>@FormatDateTime(log.EndedAt)</td>
                        <td>@FormatDuration(log)</td>
                        <td>@(log.Location ?? "Not set")</td>
                        <td>@GetNotesPreview(log)</td>
                        <td>
                            <div class="collection-table-actions">
                                <button class="collection-table-action collection-table-action-edit"
                                        type="button"
                                        title="Edit @GetLogTitle(log)"
                                        aria-label="Edit @GetLogTitle(log)"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => OpenEditPopup(log)">
                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                </button>
                                <button class="collection-table-action collection-table-action-remove"
                                        type="button"
                                        title="Remove @GetLogTitle(log)"
                                        aria-label="Remove @GetLogTitle(log)"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => RemoveLog(log)">
                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</CollectionPageShell>
