@page "/games"
@using VGL.Models.Games

@inherits CollectionPageBase<VGL.Models.Games.Game>

<PageTitle>Games</PageTitle>

<CollectionPageShell Title="Games"
                     Description="Your saved game library."
                     AddButtonText="Add Game"
                     OnAdd="OpenAddPopup"
                     IsEmpty="@(Items.Count == 0)"
                     EmptyTitle="No games added yet"
                     EmptyDescription="Add a game to start building your library.">
    <ul class="collection-grid">
        @foreach (Game game in Items)
        {
            <li>
                <LibraryEntry Entry="game"
                              OnClick="() => OpenEditPopup(game)"
                              OnRemove="() => RemoveGame(game)"/>
            </li>
        }
    </ul>
</CollectionPageShell>
