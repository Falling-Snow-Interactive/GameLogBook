@using VGL.Models
@using VGL.Models.Games
@using PlatformModel = VGL.Models.Platforms.Platform

<AddPopup Title="@PopupTitle"
          ShowSearch="false"
          OnClose="HandleClose">
    <div class="playthrough-details-form">
        <AddPopupSection Title="Information">
            <EntryField Label="Name" Class="form-span-wide">
                <input class="playthrough-detail-input"
                       @bind="playthroughName"
                       @bind:event="oninput"
                       placeholder="Playthrough name" />
            </EntryField>

            <EntryField Label="Status">
                <EnumDropdown TEnum="PlaythroughStatus" class="playthrough-detail-input" @bind-Value="status" />
            </EntryField>

            <EntryField Label="Game">
                <GameSearch Games="LibraryGames"
                            Placeholder="Search games..."
                            OnGameAdded="OnGameAdded"
                            @bind-SelectedGameId="selectedGameId" />
            </EntryField>

            <EntryField Label="Platform">
                <PlatformSearch Platforms="Platforms"
                                Placeholder="Search platforms..."
                                OnPlatformAdded="OnPlatformAdded"
                                @bind-SelectedPlatformId="selectedPlatformId" />
            </EntryField>

            <EntryField Label="Run Group">
                <select class="playthrough-detail-input"
                        value="@selectedRunId"
                        @onchange="HandleRunChanged">
                    <option value="">No run group</option>
                    @foreach (PlaythroughRun run in PlaythroughRuns)
                    {
                        <option value="@run.ID">@run.Name</option>
                    }
                </select>
            </EntryField>

            <EntryField Label="New Run Group" Hint="Optional. Creates a run group and links this playthrough to it.">
                <input class="playthrough-detail-input"
                       @bind="newRunName"
                       @bind:event="oninput"
                       placeholder="Series, expansion arc, themed run..." />
            </EntryField>
        </AddPopupSection>

        <AddPopupSection Title="Manual Date Overrides">
            <EntryField Label="Started">
                <input class="playthrough-detail-input"
                       type="datetime-local"
                       value="@FormatDateTimeInput(manualStartedAt)"
                       @oninput="HandleManualStartedAtChanged" />
            </EntryField>

            <EntryField Label="Finished">
                <input class="playthrough-detail-input"
                       type="datetime-local"
                       value="@FormatDateTimeInput(manualFinishedAt)"
                       @oninput="HandleManualFinishedAtChanged" />
            </EntryField>

            <EntryField Label="Mastered">
                <input class="playthrough-detail-input"
                       type="datetime-local"
                       value="@FormatDateTimeInput(manualMasteredAt)"
                       @oninput="HandleManualMasteredAtChanged" />
            </EntryField>
        </AddPopupSection>

        <AddPopupActions>
            <button class="save-button"
                    type="button"
                    @onclick="HandleSavePlaythrough"
                    disabled="@(!CanSave)">
                @SaveButtonText
            </button>
        </AddPopupActions>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="error-message">@errorMessage</p>
        }
    </div>
</AddPopup>
