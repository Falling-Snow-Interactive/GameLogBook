@using VGL.Components.Popups.AddPopup

<AddPopup Title="@PopupTitle"
          Description="Search the shared catalog, import from IGDB, or save a local fallback for offline use."
          SearchFor="@IgdbSearchFor.Companies"
          SearchPlaceholder="Search for a company"
          PopupClass="popup company-popup"
          FormClass="company-form"
          OnClose="HandleClose"
          OnCompanySelected="HandleCompanySelected">
    
    <EntryField Label="Name">
        <input class="text-input"
               @bind="name"
               @bind:event="oninput"
               placeholder="Name..."/>
    </EntryField>

    <EntryField Label="Summary">
        <input class="detail-textarea"
               @bind="summary"
               @bind:event="oninput"
               placeholder="Summary..."/>
    </EntryField>

    <AddPopupActions>
        <button class="save-button"
                type="button"
                disabled="@(isSaving || string.IsNullOrWhiteSpace(name))"
                @onclick="HandleSaveCompany">
            @(isSaving ? "Saving image..." : SaveButtonText)
        </button>
    </AddPopupActions>
</AddPopup>
