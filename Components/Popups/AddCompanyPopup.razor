@using VGL.Components.Popups.AddPopup

<AddPopup Title="@PopupTitle"
          Description="Search the shared catalog, import from IGDB, or save a local fallback for offline use."
          ShowSearch="false"
          PopupClass="popup company-popup"
          FormClass="company-form"
          OnClose="HandleClose"
          OnCompanySelected="HandleCompanySelected">

    <AddPopupSection Title="Information">
        <EntryField Label="Name" Class="form-span-all" UseLabel="false">
            <IGDBSearch Label="Name"
                        SearchFor="@IgdbSearchFor.Companies"
                        Placeholder="Name..."
                        Inline="true"
                        @bind-Value="name"
                        OnCompanySelected="HandleCompanySelected" />
        </EntryField>

        <EntryField Label="Founded Date">
            <input class="text-input"
                   type="date"
                   @bind="foundedDate"
                   @bind:event="oninput"/>
        </EntryField>

        <EntryField Label="Summary" Class="form-span-all">
            <textarea class="detail-textarea"
                      @bind="summary"
                      @bind:event="oninput"
                      placeholder="Summary..."></textarea>
        </EntryField>
    </AddPopupSection>

    <AddPopupSection Title="Images">
        <ImageFieldWidget @ref="coverField" class="form-span-wide"
                          Label="Cover" FieldName="cover" Category="companies"
                          ImageRef="cover" AspectRatio="1" AltText="@($"{name} cover preview")"
                          SteamGridDbSearchEnabled="true"
                          SteamGridDbImageType="@SteamGridDbImageType.Cover"
                          SteamGridDbSearchTerm="@name" />

        <ImageFieldWidget @ref="logoField" class="form-span-wide"
                          Label="Logo" FieldName="logo" Category="companies"
                          ImageRef="logo" AspectRatio="1" AltText="@($"{name} logo preview")"
                          SteamGridDbSearchEnabled="true"
                          SteamGridDbImageType="@SteamGridDbImageType.Logo"
                          SteamGridDbSearchTerm="@name" />

        <ImageFieldWidget @ref="heroField" class="form-span-wide"
                          Label="Hero" FieldName="hero" Category="companies"
                          ImageRef="hero" AspectRatio="1" AltText="@($"{name} hero preview")"
                          SteamGridDbSearchEnabled="true"
                          SteamGridDbImageType="@SteamGridDbImageType.Hero"
                          SteamGridDbSearchTerm="@name" />

        <ImageFieldWidget @ref="iconField" class="form-span-wide"
                          Label="Icon" FieldName="icon" Category="companies"
                          ImageRef="icon" AspectRatio="1" AltText="@($"{name} icon preview")"
                          SteamGridDbSearchEnabled="true"
                          SteamGridDbImageType="@SteamGridDbImageType.Icon"
                          SteamGridDbSearchTerm="@name" />
    </AddPopupSection>

    @if (!string.IsNullOrWhiteSpace(imageErrorMessage))
    {
        <p class="form-hint">@imageErrorMessage</p>
    }

    <AddPopupSection Title="APIs">
        <EntryField Label="IGDB ID">
            <input class="text-input"
                   type="number"
                   @bind="igdb"
                   @bind:event="oninput"
                   placeholder="id" />
        </EntryField>
    </AddPopupSection>

    <AddPopupActions>
        <button class="save-button"
                type="button"
                disabled="@(isSaving || string.IsNullOrWhiteSpace(name))"
                @onclick="HandleSaveCompany">
            @(isSaving ? "Saving image..." : SaveButtonText)
        </button>
    </AddPopupActions>
</AddPopup>
