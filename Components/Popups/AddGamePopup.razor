@using VGL.Models.Games

<AddPopup Title="@PopupTitle"
          ShowSearch="false"
          OnClose="HandleCloseButtonClick"
          OnGameSelected="HandleGameSelected"
          LocalCompanies="@Companies">
    <div class="game-details-form">
        <AddPopupSection Title="Information">
            <EntryField Label="Name" Class="form-span-all" UseLabel="false">
                <IGDBSearch Label="Name"
                            SearchFor="@IgdbSearchFor.Games"
                            Placeholder="Game name"
                            Inline="true"
                            @bind-Value="name"
                            LocalCompanies="@availableCompanies"
                            OnGameSelected="HandleGameSelected" />
            </EntryField>

            <EntryField Label="Release Date">
                <input class="game-detail-input" type="date" @bind="releaseDate" @bind:event="oninput" placeholder="Release date" />
            </EntryField>

            <EntryField Label="Type">
                <EnumDropdown TEnum="GameType" class="game-detail-input" @bind-Value="type" />
            </EntryField>

            <EntryField Label="Rating" UseLabel="false">
                <StarRating @bind-Value="rating" AriaLabel="Game rating" />
            </EntryField>

            <EntryField Label="Ownership">
                <OwnershipInputWidget Platforms="Platforms"
                                      @bind-Ownerships="selectedPlatformOwnerships" />
            </EntryField>

            <EntryField Label="Summary" Class="form-span-all">
                <textarea class="game-detail-textarea" @bind="summary" @bind:event="oninput" placeholder="Summary"></textarea>
            </EntryField>

            @if (availableCompanies.Count == 0)
            {
                <EntryField Class="form-span-all" Hint="No shared companies exist yet, so this game will save without developer or publisher links." />
            }

            <EntryField Label="Developer" Class="form-span-wide" UseLabel="false">
                <CompanySearch Companies="availableCompanies"
                               @bind-SelectedCompanyIds="selectedDeveloperIDs"
                               @bind-SearchText="developerSearchText"
                               OnCompanyAdded="HandleCompanyAdded"
                               Placeholder="Search companies..." />
            </EntryField>

            <EntryField Label="Publisher" Class="form-span-wide" UseLabel="false">
                <CompanySearch Companies="availableCompanies"
                               @bind-SelectedCompanyIds="selectedPublisherIDs"
                               @bind-SearchText="publisherSearchText"
                               OnCompanyAdded="HandleCompanyAdded"
                               Placeholder="Search companies..." />
            </EntryField>
        </AddPopupSection>

        <AddPopupSection Title="Images">
            <ImageFieldWidget @ref="coverField" class="form-span-wide"
                              Label="Cover" FieldName="cover" Category="games"
                              ImageRef="cover" AspectRatio="1" AltText="@($"{name} cover preview")" />

            <ImageFieldWidget @ref="logoField" class="form-span-wide"
                              Label="Logo" FieldName="logo" Category="games"
                              ImageRef="logo" AspectRatio="1" AltText="@($"{name} logo preview")" />

            <ImageFieldWidget @ref="heroField" class="form-span-wide"
                              Label="Hero" FieldName="hero" Category="games"
                              ImageRef="hero" AspectRatio="1" AltText="@($"{name} hero preview")" />

            <ImageFieldWidget @ref="iconField" class="form-span-wide"
                              Label="Icon" FieldName="icon" Category="games"
                              ImageRef="icon" AspectRatio="1" AltText="@($"{name} icon preview")" />
        </AddPopupSection>

        @if (!string.IsNullOrWhiteSpace(imageErrorMessage))
        {
            <p class="form-hint">@imageErrorMessage</p>
        }

        <AddPopupSection Title="APIs">
            <EntryField Label="IGDB ID">
                <input class="game-detail-input" type="number" @bind="igdb" @bind:event="oninput" placeholder="id" />
            </EntryField>
        </AddPopupSection>

        <AddPopupActions>
            <button class="save-button" type="button" @onclick="HandleSaveButtonClick" 
                    disabled="@(isSaving || string.IsNullOrWhiteSpace(name))">
                @(isSaving ? "Saving image..." : SaveButtonText)
            </button>
        </AddPopupActions>
    </div>
</AddPopup>
