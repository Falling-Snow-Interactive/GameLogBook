@using VGL.Models.Companies
@using VGL.Models.Games

<AddPopup Title="@Title"
          Description="@Description"
          SearchFor="@SearchFor"
          SearchPlaceholder="@SearchPlaceholder"
          PopupClass="@PopupClass"
          FormClass="@FormClass"
          ShowSearch="@ShowSearch"
          OnClose="@OnClose"
          OnGameSelected="@OnGameSelected"
          OnPlatformSelected="@OnPlatformSelected"
          OnCompanySelected="@OnCompanySelected"
          LocalCompanies="@LocalCompanies">
    @ChildContent
</AddPopup>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter, EditorRequired]
    public IgdbSearchFor SearchFor { get; set; }

    [Parameter, EditorRequired]
    public string SearchPlaceholder { get; set; } = string.Empty;

    [Parameter]
    public string PopupClass { get; set; } = "popup";

    [Parameter]
    public string? FormClass { get; set; }

    [Parameter]
    public bool ShowSearch { get; set; } = true;

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<Game> OnGameSelected { get; set; }

    [Parameter]
    public EventCallback<IGDBSearchPlatformResult> OnPlatformSelected { get; set; }

    [Parameter]
    public EventCallback<Company> OnCompanySelected { get; set; }

    [Parameter]
    public IReadOnlyList<Company> LocalCompanies { get; set; } = [];

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

}
