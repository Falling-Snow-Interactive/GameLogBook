@using VGL.Models
@using VGL.Models.Games
@using PlatformModel = VGL.Models.Platforms.Platform

<AddPopup Title="@PopupTitle"
          ShowSearch="false"
          OnClose="HandleClose">
    <div class="playthrough-details-form">
        <AddPopupSection Title="Session">
            <EntryField Label="Title" Class="form-span-wide" Hint="Optional. Leave blank to use the game and start time.">
                <input class="playthrough-detail-input"
                       @bind="title"
                       @bind:event="oninput"
                       placeholder="Session title" />
            </EntryField>

            <EntryField Label="Playthrough">
                <select class="playthrough-detail-input"
                        value="@selectedPlaythroughId"
                        @onchange="HandlePlaythroughChanged">
                    <option value="">Select a playthrough...</option>
                    @foreach (Playthrough playthrough in Playthroughs)
                    {
                        <option value="@playthrough.ID">@playthrough.Name</option>
                    }
                </select>
            </EntryField>

            <EntryField Label="Game">
                <GameSearch Games="LibraryGames"
                            Placeholder="Search games..."
                            OnGameAdded="OnGameAdded"
                            @bind-SelectedGameId="selectedGameId" />
            </EntryField>

            <EntryField Label="Platform">
                <PlatformSearch Platforms="Platforms"
                                Placeholder="Search platforms..."
                                OnPlatformAdded="OnPlatformAdded"
                                @bind-SelectedPlatformId="selectedPlatformId" />
            </EntryField>

            <EntryField Label="Status Change">
                <select class="playthrough-detail-input"
                        value="@statusChangeValue"
                        @onchange="HandleStatusChangeChanged">
                    <option value="">No change</option>
                    @foreach (PlaythroughStatus option in Enum.GetValues<PlaythroughStatus>())
                    {
                        <option value="@option">@option</option>
                    }
                </select>
            </EntryField>
        </AddPopupSection>

        <AddPopupSection Title="Time and Place">
            <EntryField Label="Started">
                <input class="playthrough-detail-input"
                       type="datetime-local"
                       @bind="startedAt"
                       @bind:format="yyyy-MM-ddTHH:mm" />
            </EntryField>

            <EntryField Label="Ended">
                <input class="playthrough-detail-input"
                       type="datetime-local"
                       @bind="endedAt"
                       @bind:format="yyyy-MM-ddTHH:mm" />
            </EntryField>

            <EntryField Label="Location">
                <input class="playthrough-detail-input"
                       @bind="location"
                       @bind:event="oninput"
                       placeholder="Couch, commute, vacation..." />
            </EntryField>
        </AddPopupSection>

        <AddPopupSection Title="Notes">
            <EntryField Label="Notes" Class="form-span-all">
                <textarea class="playthrough-detail-textarea"
                          @bind="notes"
                          @bind:event="oninput"
                          placeholder="Bosses beaten, story beats, thoughts, goals for next time..."></textarea>
            </EntryField>
        </AddPopupSection>

        <AddPopupActions>
            <button class="save-button"
                    type="button"
                    @onclick="HandleSaveLog"
                    disabled="@(!CanSave)">
                @SaveButtonText
            </button>
        </AddPopupActions>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="error-message">@errorMessage</p>
        }
    </div>
</AddPopup>
