<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
    </PropertyGroup>

    <ItemGroup>
      <StaticWebAssetContentTypeMapping Remove="font\otf" />
      <StaticWebAssetContentTypeMapping Remove="font\woff2" />
    </ItemGroup>

    <ItemGroup>
      <Folder Include="Data\Migrations\" />
      <Folder Include="wwwroot\css\" />
    </ItemGroup>

    <ItemGroup>
      <Compile Update="Components\Pages\Library.razor.cs">
        <DependentUpon>Library.razor</DependentUpon>
      </Compile>
    </ItemGroup>

</Project>
